@model Coupon

@{
    ViewData["Title"] = "Edit Coupon";
}

<form method="post">
    <input asp-for="Id" hidden />
    <input asp-for="CreatedDate" hidden />
    
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Edit Coupon</h2>
            <hr />
        </div>
        <div asp-validation-summary="All"></div>
        
        <div class="mb-3 row p-1">
            <label asp-for="Code" class="p-0"></label>
            <input asp-for="Code" class="form-control" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>

        <div class="mb-3 row p-1">
            <label asp-for="DiscountPercent" class="p-0"></label>
            <input asp-for="DiscountPercent" class="form-control" />
            <span asp-validation-for="DiscountPercent" class="text-danger"></span>
        </div>

        <div class="mb-3 row p-1">
            <label asp-for="IsActive" class="p-0"></label>
            <input asp-for="IsActive" class="form-check-input" style="width: 20px; height: 20px;" />
        </div>

        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-primary form-control">Update</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Coupon" asp-action="Index" class="btn btn-secondary border form-control">
                    Back to List
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}
