@model OrderVM
<form method="post">
    <input asp-for="OrderHeader.Id" hidden />
    
    <div class="container my-4">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="fw-bold mb-1" style="color: #ff3131;">
                    <i class="bi bi-receipt me-2"></i>Order #@Model.OrderHeader.Id
                </h2>
                <p class="text-muted mb-0 small">Placed on @Model.OrderHeader.OrderDate.ToString("MMM dd, yyyy")</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
        </div>

        <div class="row g-3">
            <!-- Left Column: Information -->
            <div class="col-lg-8">
                <!-- Customer & Shipping Info -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-3">
                        <div class="row g-3">
                            <!-- Customer Info -->
                            <div class="col-md-6">
                                <div class="info-section">
                                    <h6 class="fw-bold mb-2" style="color: #ff3131; font-size: 0.9rem;">
                                        <i class="bi bi-person-circle me-1"></i>Customer
                                    </h6>
                                    @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee)) {
                                        <div class="info-item">
                                            <label class="info-label">Name</label>
                                            <input asp-for="OrderHeader.Name" type="text" class="info-input" />
                                        </div>
                                        <div class="info-item">
                                            <label class="info-label">Phone</label>
                                            <input asp-for="OrderHeader.PhoneNumber" type="text" class="info-input" />
                                        </div>
                                    } else {
                                        <div class="info-item">
                                            <span class="info-label">Name</span>
                                            <span class="info-value">@Model.OrderHeader.Name</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Phone</span>
                                            <span class="info-value">@Model.OrderHeader.PhoneNumber</span>
                                        </div>
                                    }
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">@Model.OrderHeader.ApplicationUser.Email</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Shipping Address -->
                            <div class="col-md-6">
                                <div class="info-section">
                                    <h6 class="fw-bold mb-2" style="color: #ff3131; font-size: 0.9rem;">
                                        <i class="bi bi-geo-alt me-1"></i>Shipping Address
                                    </h6>
                                    @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee)) {
                                        <div class="info-item">
                                            <label class="info-label">Street</label>
                                            <input asp-for="OrderHeader.StreetAddress" type="text" class="info-input" />
                                        </div>
                                        <div class="row g-2">
                                            <div class="col-6">
                                                <div class="info-item">
                                                    <label class="info-label">City</label>
                                                    <input asp-for="OrderHeader.City" type="text" class="info-input" />
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="info-item">
                                                    <label class="info-label">State</label>
                                                    <input asp-for="OrderHeader.State" type="text" class="info-input" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="info-item">
                                            <label class="info-label">Postal Code</label>
                                            <input asp-for="OrderHeader.PostalCode" type="text" class="info-input" />
                                        </div>
                                    } else {
                                        <div class="info-item mb-0">
                                            <span class="info-value">
                                                @Model.OrderHeader.StreetAddress<br />
                                                @Model.OrderHeader.City, @Model.OrderHeader.State @Model.OrderHeader.PostalCode
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Shipping Details -->
                            <div class="col-12">
                                <hr class="my-2" />
                                <h6 class="fw-bold mb-2" style="color: #ff3131; font-size: 0.9rem;">
                                    <i class="bi bi-truck me-1"></i>Shipping Details
                                </h6>
                                <div class="row g-2">
                                    @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee)) {
                                        <div class="col-md-3">
                                            <div class="info-item">
                                                <label class="info-label">Carrier</label>
                                                <input asp-for="OrderHeader.Carrier" id="carrier" type="text" class="info-input" placeholder="e.g., FedEx" />
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="info-item">
                                                <label class="info-label">Tracking</label>
                                                <input asp-for="OrderHeader.TrackingNumber" id="trackingNumber" type="text" class="info-input" placeholder="Tracking #" />
                                            </div>
                                        </div>
                                    } else {
                                        <div class="col-md-3">
                                            <div class="info-item">
                                                <span class="info-label">Carrier</span>
                                                <span class="info-value">@(string.IsNullOrEmpty(Model.OrderHeader.Carrier) ? "N/A" : Model.OrderHeader.Carrier)</span>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="info-item">
                                                <span class="info-label">Tracking</span>
                                                <span class="info-value">@(string.IsNullOrEmpty(Model.OrderHeader.TrackingNumber) ? "N/A" : Model.OrderHeader.TrackingNumber)</span>
                                            </div>
                                        </div>
                                    }
                                    <div class="col-md-3">
                                        <div class="info-item">
                                            <span class="info-label">Estimated Delivery</span>
                                            <span class="info-value">@Model.OrderHeader.ShippingDate.ToString("MMM dd") - @Model.OrderHeader.ShippingDate.AddDays(2).ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="badge bg-primary">@Model.OrderHeader.OrderStatus</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee)) {
                            <div class="mt-3">
                                <button type="submit" asp-action="UpdateOrderDetail" class="btn btn-danger btn-sm">
                                    <i class="bi bi-check-circle me-1"></i>Update Details
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column: Order Summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-2" style="color: #ff3131; font-size: 0.9rem;">
                            <i class="bi bi-receipt-cutoff me-1"></i>Order Summary
                        </h6>

                        <!-- Payment Status -->
                        <div class="mb-2 p-2" style="background: #f9fafb; border-radius: 6px;">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <small class="text-muted" style="font-size: 0.7rem;">Payment</small>
                                <span class="badge px-2 py-1" style="background: @(Model.OrderHeader.PaymentStatus == "Approved" ? "#10b981" : "#f59e0b"); font-size: 0.65rem;">
                                    @Model.OrderHeader.PaymentStatus
                                </span>
                            </div>
                            @if (Model.OrderHeader.SessionId == null) {
                                <div class="d-flex justify-content-between">
                                    <small style="font-size: 0.7rem;">Due:</small>
                                    <small class="fw-semibold" style="font-size: 0.7rem;">@Model.OrderHeader.PaymentDueDate.ToShortDateString()</small>
                                </div>
                            } else {
                                <div class="d-flex justify-content-between mb-1">
                                    <small style="font-size: 0.7rem;">Date:</small>
                                    <small class="fw-semibold" style="font-size: 0.7rem;">@Model.OrderHeader.PaymentDate.ToShortDateString()</small>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.OrderHeader.PaymentIntentId)) {
                                    <div class="pt-1 border-top">
                                        <small class="text-muted d-block" style="font-size: 0.65rem;">Transaction</small>
                                        <small class="fw-semibold text-break" style="font-size: 0.7rem; color: #10b981;">
                                            @Model.OrderHeader.PaymentIntentId
                                        </small>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.OrderHeader.SessionId) && Model.OrderHeader.SessionId.Contains("|")) {
                                    var paymentMethod = Model.OrderHeader.SessionId.Split('|')[1];
                                    <div class="pt-1 border-top">
                                        <small class="text-muted d-block" style="font-size: 0.65rem;">Method</small>
                                        <small class="fw-semibold" style="font-size: 0.7rem; color: #6366f1;">
                                            @paymentMethod
                                        </small>
                                    </div>
                                }
                            }
                        </div>

                        <!-- Order Items -->
                        <div class="order-items mb-2" style="max-height: 250px; overflow-y: auto;">
                            @foreach (var detail in Model.OrderDetail) {
                                <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                    <div style="flex: 1;">
                                        <p class="mb-0 fw-bold" style="font-size: 0.8rem;">@detail.Product.Title</p>
                                        <small class="text-muted" style="font-size: 0.7rem;">@detail.Price.ToString("c") × @detail.Count</small>
                                    </div>
                                    <span class="fw-bold" style="font-size: 0.85rem; color: #10b981;">@((detail.Count * detail.Price).ToString("c"))</span>
                                </div>
                            }
                        </div>

                        <!-- Total -->
                        <div class="p-2 text-white text-center" style="background: linear-gradient(135deg, #ff3131, #e62020); border-radius: 6px;">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold" style="font-size: 0.85rem;">Total</span>
                                <span class="fw-bold" style="font-size: 1.1rem;">@Model.OrderHeader.OrderTotal.ToString("c")</span>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="mt-2">
                            @if (Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment && Model.OrderHeader.OrderStatus == SD.StatusShipped) {
                                <button type="submit" class="btn btn-success btn-sm w-100 mb-1">
                                    <i class="bi bi-credit-card me-1"></i>Pay Now
                                </button>
                            }
                            
                            @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee)) {
                                @if (Model.OrderHeader.OrderStatus == SD.StatusApproved) {
                                    <button type="submit" asp-action="StartProcessing" class="btn btn-danger btn-sm w-100 mb-1">
                                        <i class="bi bi-play-circle me-1"></i>Start Processing
                                    </button>
                                }
                                
                                @if (Model.OrderHeader.OrderStatus == SD.StatusInProcess) {
                                    <button type="submit" asp-action="ShipOrder" onclick="return validateInput()" class="btn btn-danger btn-sm w-100 mb-1">
                                        <i class="bi bi-truck me-1"></i>Ship Order
                                    </button>
                                }
                                
                                @if (Model.OrderHeader.OrderStatus != SD.StatusRefunded && 
                                     Model.OrderHeader.OrderStatus != SD.StatusCancelled && 
                                     Model.OrderHeader.OrderStatus != SD.StatusShipped) {
                                    <button asp-action="CancelOrder" type="submit" class="btn btn-outline-danger btn-sm w-100">
                                        <i class="bi bi-x-circle me-1"></i>Cancel
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function validateInput() {
            if (document.getElementById("trackingNumber").value == "") {
                Swal.fire({
                    icon: 'error',
                    title: 'Required',
                    text: 'Please enter tracking number',
                    confirmButtonColor: '#ff3131'
                });
                return false;
            }
            if (document.getElementById("carrier").value == "") {
                Swal.fire({
                    icon: 'error',
                    title: 'Required',
                    text: 'Please enter carrier',
                    confirmButtonColor: '#ff3131'
                });
                return false;
            }
            return true;
        }
    </script>
    <style>
        .info-section {
            padding: 0;
        }
        .info-item {
            margin-bottom: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }
        .info-label {
            font-size: 0.7rem;
            color: #6b7280;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .info-value {
            font-size: 0.85rem;
            color: #1f2937;
            font-weight: 500;
        }
        .info-input {
            border: none;
            border-bottom: 2px solid #e5e7eb;
            padding: 0.25rem 0;
            font-size: 0.85rem;
            transition: border-color 0.2s;
            background: transparent;
        }
        .info-input:focus {
            outline: none;
            border-bottom-color: #ff3131;
        }
        .order-items::-webkit-scrollbar {
            width: 4px;
        }
        .order-items::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }
        .order-items::-webkit-scrollbar-thumb {
            background: #ff3131;
            border-radius: 4px;
        }
    </style>
}
