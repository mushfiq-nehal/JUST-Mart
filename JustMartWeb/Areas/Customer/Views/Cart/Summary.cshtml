@model ShoppingCartVM

<form method="post">
    <div class="container my-5">
        <!-- Modern Header -->
        <div class="mb-5">
            <h1 class="display-5 fw-bold mb-2" style="color: #ff3131;">
                <i class="bi bi-bag-check me-3"></i>Checkout
            </h1>
            <p class="text-muted">Complete your order details</p>
        </div>

        <div class="row g-4">
            <!-- Shipping Details -->
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4" style="color: #ff3131;">
                            <i class="bi bi-truck me-2"></i>Shipping Details
                        </h5>

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold">Full Name</label>
                                <input asp-for="OrderHeader.Name" class="form-control form-control-lg" style="border-radius: 12px;" placeholder="Enter your full name" />
                                <span asp-validation-for="OrderHeader.Name" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Phone Number</label>
                                <input asp-for="OrderHeader.PhoneNumber" class="form-control form-control-lg" style="border-radius: 12px;" placeholder="Enter your phone number" />
                                <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Street Address</label>
                                <input asp-for="OrderHeader.StreetAddress" class="form-control form-control-lg" style="border-radius: 12px;" placeholder="House number and street name" />
                                <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">City</label>
                                <input asp-for="OrderHeader.City" class="form-control form-control-lg" style="border-radius: 12px;" placeholder="Enter city" />
                                <span asp-validation-for="OrderHeader.City" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">State/Province</label>
                                <input asp-for="OrderHeader.State" class="form-control form-control-lg" style="border-radius: 12px;" placeholder="Enter state" />
                                <span asp-validation-for="OrderHeader.State" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Postal Code</label>
                                <input asp-for="OrderHeader.PostalCode" class="form-control form-control-lg" style="border-radius: 12px;" placeholder="ZIP or postal code" />
                                <span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4 p-3" style="background: rgba(16, 185, 129, 0.05); border-radius: 12px; border-left: 4px solid #10b981;">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-clock-history" style="font-size: 1.5rem; color: #10b981;"></i>
                                <div class="ms-3">
                                    <small class="fw-semibold d-block">Estimated Delivery</small>
                                    <small class="text-muted">@DateTime.Now.AddDays(5).ToString("MMM dd") - @DateTime.Now.AddDays(7).ToString("MMM dd, yyyy")</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 12px;">
                    <i class="bi bi-arrow-left me-2"></i>Back to Cart
                </a>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm sticky-top" style="border-radius: 16px; top: 100px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Order Summary</h5>

                        <!-- Order Items -->
                        <div class="order-items mb-4" style="max-height: 300px; overflow-y: auto;">
                            @foreach(var details in Model.ShoppingCartList){
                            <div class="d-flex align-items-start mb-3 pb-3 border-bottom">
                                <div class="position-relative me-3">
                                    @if (details.Product.ProductImages != null && details.Product.ProductImages.Any()) {
                                        <img src="@details.Product.ProductImages.FirstOrDefault().ImageUrl" 
                                             class="rounded" 
                                             style="width: 60px; height: 60px; object-fit: cover;" 
                                             alt="@details.Product.Title" />
                                    } else {
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center" 
                                             style="width: 60px; height: 60px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" 
                                          style="font-size: 0.7rem;">
                                        @details.Count
                                    </span>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 fw-semibold">@details.Product.Title</h6>
                                    <small class="text-muted">Qty: @details.Count</small>
                                </div>
                                <div class="text-end">
                                    <span class="fw-bold">@((details.Price*details.Count).ToString("c"))</span>
                                </div>
                            </div>
                            }
                        </div>

                        <!-- Coupon Section -->
                        <div class="mb-4 p-3" style="background: rgba(255, 49, 49, 0.05); border-radius: 12px; border: 1px solid rgba(255, 49, 49, 0.2);">
                            <h6 class="fw-semibold mb-3" style="color: #ff3131;">
                                <i class="bi bi-ticket-perforated me-2"></i>Have a Coupon?
                            </h6>
                            <div class="input-group">
                                <input type="text" id="couponCode" class="form-control" placeholder="Enter coupon code" style="border-radius: 8px 0 0 8px;">
                                <button type="button" class="btn text-white" id="applyCouponBtn" style="background: #ff3131; border-radius: 0 8px 8px 0;">
                                    Apply
                                </button>
                            </div>
                            <div id="couponMessage" class="mt-2"></div>
                            <div id="appliedCouponSection" class="mt-3" style="display: none;">
                                <div class="d-flex justify-content-between align-items-center p-2" style="background: rgba(16, 185, 129, 0.1); border-radius: 8px;">
                                    <div>
                                        <small class="text-success fw-semibold">
                                            <i class="bi bi-check-circle me-1"></i>Coupon Applied: <span id="appliedCouponCode"></span>
                                        </small>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-link text-danger p-0" id="removeCouponBtn">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Pricing Breakdown -->
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Subtotal</span>
                            <span class="fw-semibold" id="subtotal">@Model.OrderHeader.OrderTotal.ToString("c")</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Shipping</span>
                            <span class="fw-semibold text-success">FREE</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3" id="couponDiscountRow" style="display: none;">
                            <span class="text-success">
                                <i class="bi bi-tag me-1"></i>Coupon Discount
                            </span>
                            <span class="fw-semibold text-success" id="couponDiscountAmount">-৳0</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tax</span>
                            <span class="fw-semibold">Included</span>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between mb-4">
                            <h5 class="fw-bold">Total</h5>
                            <h5 class="fw-bold" style="color: #ff3131;" id="orderTotal">@Model.OrderHeader.OrderTotal.ToString("c")</h5>
                        </div>

                        <!-- Hidden fields for coupon -->
                        <input type="hidden" asp-for="OrderHeader.CouponCode" id="hiddenCouponCode" />
                        <input type="hidden" asp-for="OrderHeader.CouponDiscount" id="hiddenCouponDiscount" />

                        <!-- Place Order Button -->
                        <div class="d-grid gap-2">
                            <button type="submit" 
                                    class="btn btn-lg text-white" 
                                    style="background: linear-gradient(135deg, rgba(255, 49, 49, 0.9) 0%, rgba(230, 32, 32, 0.85) 100%); border: none; border-radius: 12px; box-shadow: 0 4px 15px rgba(255, 49, 49, 0.3);">
                                <i class="bi bi-credit-card me-2"></i>Place Order
                            </button>
                        </div>

                        <!-- Security Badge -->
                        <div class="mt-4 p-3" style="background: rgba(255, 49, 49, 0.05); border-radius: 12px; border-left: 4px solid #ff3131;">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-shield-check" style="font-size: 1.5rem; color: #ff3131;"></i>
                                <small class="ms-2 fw-semibold">Secure Checkout</small>
                            </div>
                            <small class="text-muted">Your payment information is protected with 256-bit SSL encryption</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const originalTotal = @Model.OrderHeader.OrderTotal;
            let appliedDiscount = 0;
            let appliedCouponCode = '';

            // Apply Coupon
            $('#applyCouponBtn').click(function () {
                const couponCode = $('#couponCode').val().trim();
                if (!couponCode) {
                    showMessage('Please enter a coupon code', 'danger');
                    return;
                }

                $.ajax({
                    url: '/Customer/Cart/ApplyCoupon',
                    type: 'POST',
                    data: { couponCode: couponCode, orderTotal: originalTotal },
                    success: function (response) {
                        if (response.success) {
                            appliedDiscount = response.discountAmount;
                            appliedCouponCode = couponCode.toUpperCase();
                            
                            // Update UI
                            $('#appliedCouponCode').text(appliedCouponCode);
                            $('#appliedCouponSection').show();
                            $('#couponCode').prop('disabled', true);
                            $('#applyCouponBtn').prop('disabled', true);
                            
                            // Update totals
                            updateTotals();
                            
                            // Update hidden fields
                            $('#hiddenCouponCode').val(appliedCouponCode);
                            $('#hiddenCouponDiscount').val(appliedDiscount);
                            
                            showMessage(response.message, 'success');
                        } else {
                            showMessage(response.message, 'danger');
                        }
                    },
                    error: function () {
                        showMessage('Error applying coupon. Please try again.', 'danger');
                    }
                });
            });

            // Remove Coupon
            $('#removeCouponBtn').click(function () {
                appliedDiscount = 0;
                appliedCouponCode = '';
                
                // Reset UI
                $('#appliedCouponSection').hide();
                $('#couponCode').val('').prop('disabled', false);
                $('#applyCouponBtn').prop('disabled', false);
                
                // Update totals
                updateTotals();
                
                // Clear hidden fields
                $('#hiddenCouponCode').val('');
                $('#hiddenCouponDiscount').val('0');
                
                $('#couponMessage').html('');
            });

            function updateTotals() {
                const newTotal = originalTotal - appliedDiscount;
                
                if (appliedDiscount > 0) {
                    $('#couponDiscountRow').show();
                    $('#couponDiscountAmount').text('-৳' + appliedDiscount.toFixed(2));
                } else {
                    $('#couponDiscountRow').hide();
                }
                
                $('#orderTotal').text('৳' + newTotal.toFixed(2));
            }

            function showMessage(message, type) {
                const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
                const icon = type === 'success' ? 'bi-check-circle' : 'bi-exclamation-circle';
                
                $('#couponMessage').html(`
                    <div class="alert ${alertClass} alert-dismissible fade show py-2 px-3" role="alert" style="border-radius: 8px;">
                        <i class="bi ${icon} me-1"></i>
                        <small>${message}</small>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                `);
            }
        });
    </script>
}