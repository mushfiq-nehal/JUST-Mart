@model IEnumerable<Product>

<!-- Hero Banner -->
<section class="hero-banner">
    <img src="~/banner/Website banner.png" alt="JUST Mart Banner" class="img-fluid w-100" />
</section>

<!-- Categories Section -->
<section class="py-4" id="products">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3" data-aos="fade-up">
            <div>
                <h5 class="fw-bold mb-0">Shop by Category</h5>
            </div>
        </div>
        <div class="categories-scroll-container">
            <div class="categories-scroll">
            @{
                var categories = ViewBag.Categories as List<JustMart.Models.Category>;
                var categoryIcons = new Dictionary<string, string> {
                    { "Action", "bi-lightning-charge" },
                    { "SciFi", "bi-rocket" },
                    { "History", "bi-book" },
                    { "Fashion", "bi-bag" },
                    { "Hand Crafted", "bi-palette" },
                    { "Food", "bi-basket" },
                    { "Gadgets", "bi-cpu" }
                };
                int delay = 100;
            }
            
            @* Show All Products card *@
            <a asp-action="Index" asp-controller="Home" asp-area="Customer" class="category-pill @(ViewBag.SelectedCategoryId == null ? "active" : "")" style="text-decoration: none;">
                <div class="category-pill-icon">
                    <i class="bi bi-grid-fill"></i>
                </div>
                <div class="category-pill-content">
                    <h6 class="mb-0">All</h6>
                    <small class="text-muted">@Model.Count()</small>
                </div>
            </a>
            
            @if (categories != null)
            {
                @foreach (var category in categories)
                {
                    delay += 100;
                    var productCount = Model.Count(p => p.CategoryId == category.Id);
                    var iconClass = categoryIcons.ContainsKey(category.Name) ? categoryIcons[category.Name] : "bi-tag";
                    var isActive = ViewBag.SelectedCategoryId == category.Id ? "active" : "";
                    
                    <a asp-action="Index" asp-controller="Home" asp-area="Customer" asp-route-categoryId="@category.Id" 
                       class="category-pill @isActive" style="text-decoration: none;">
                        <div class="category-pill-icon">
                            <i class="bi @iconClass"></i>
                        </div>
                        <div class="category-pill-content">
                            <h6 class="mb-0">@category.Name</h6>
                            <small class="text-muted">@productCount</small>
                        </div>
                    </a>
                }
            }
            </div>
        </div>
    </div>
</section>

<!-- Products Section -->
<section class="py-5">
    <div class="container">
        <div class="section-header d-flex justify-content-between align-items-center mb-5" data-aos="fade-up">
            <div class="section-header-content">
                @{
                    var selectedCategoryId = ViewBag.SelectedCategoryId as int?;
                    var categoriesList = ViewBag.Categories as List<JustMart.Models.Category>;
                    var selectedCategory = selectedCategoryId.HasValue && categoriesList != null 
                        ? categoriesList.FirstOrDefault(c => c.Id == selectedCategoryId.Value) 
                        : null;
                }
                <h2 class="section-title mb-2">@(selectedCategory != null ? selectedCategory.Name + " Products" : "Featured Products")</h2>
            </div>
            <div class="filter-controls">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="new">New</button>
                <button class="filter-btn" data-filter="sale">On Sale</button>
                <button class="filter-btn" data-filter="popular">Popular</button>
            </div>
        </div>

        <div class="products-grid">
            @foreach (var product in Model)
            {
                <div class="modern-product-card" data-aos="fade-up" data-aos-delay="@((Model.ToList().IndexOf(product) % 4) * 100)">
                    <div class="product-image-wrapper">
                        @if(product.ProductImages!=null && product.ProductImages.Count() > 0) {
                            <img src="@product.ProductImages.FirstOrDefault().ImageUrl" alt="@product.Title" class="product-main-image" />
                        }
                        else {
                            <img src="https://placehold.co/400x500/f8f9fa/667eea/png?text=@product.Title" alt="@product.Title" class="product-main-image" />
                        }
                        
                        @{
                            var displayPrice = ViewBag.IsCompanyUser == true ? product.Price100 : product.DiscountPrice;
                            var discount = product.ListPrice > displayPrice ? Math.Round(((product.ListPrice - displayPrice) / product.ListPrice) * 100) : 0;
                        }
                        
                        @if(discount > 0)
                        {
                            <div class="product-badge sale-badge">
                                <span>-@discount%</span>
                            </div>
                        }
                        
                        <div class="product-quick-actions">
                            <button class="quick-action-btn wishlist-btn" title="Add to Wishlist">
                                <i class="bi bi-heart"></i>
                            </button>
                            <button class="quick-action-btn view-btn" title="Quick View">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="quick-action-btn compare-btn" title="Compare">
                                <i class="bi bi-arrow-left-right"></i>
                            </button>
                        </div>
                        
                        <div class="product-overlay">
                            <a asp-action="Details" asp-route-productId="@product.Id" class="btn btn-view-details">
                                <span>View Details</span>
                                <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                    
                    <div class="product-info">
                        <div class="product-category">
                            <i class="bi bi-tag-fill me-1"></i>
                            <span>@product.Category.Name</span>
                        </div>
                        <h3 class="product-title">
                            <a asp-action="Details" asp-route-productId="@product.Id">@product.Title</a>
                        </h3>
                        <div class="product-rating">
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-half"></i>
                            <span class="rating-count">(4.5)</span>
                        </div>
                        <div class="product-footer">
                            <div class="product-price">
                                @{
                                    var priceToShow = ViewBag.IsCompanyUser == true ? product.Price100 : product.DiscountPrice;
                                }
                                <span class="current-price">@priceToShow.ToString("c")</span>
                                @if(product.ListPrice > priceToShow)
                                {
                                    <span class="old-price">@product.ListPrice.ToString("c")</span>
                                }
                            </div>
                            <a asp-action="Details" asp-route-productId="@product.Id" class="btn-add-cart">
                                <i class="bi bi-cart-plus"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="features-section py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3 col-sm-6" data-aos="fade-up" data-aos-delay="100">
                <div class="feature-box">
                    <div class="feature-icon">
                        <i class="bi bi-truck"></i>
                    </div>
                    <h4>Free Shipping</h4>
                    <p>On orders over 500 tk</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6" data-aos="fade-up" data-aos-delay="200">
                <div class="feature-box">
                    <div class="feature-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h4>Secure Payment</h4>
                    <p>100% protected</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6" data-aos="fade-up" data-aos-delay="300">
                <div class="feature-box">
                    <div class="feature-icon">
                        <i class="bi bi-arrow-repeat"></i>
                    </div>
                    <h4>Easy Returns</h4>
                    <p>30-day return policy</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6" data-aos="fade-up" data-aos-delay="400">
                <div class="feature-box">
                    <div class="feature-icon">
                        <i class="bi bi-headset"></i>
                    </div>
                    <h4>24/7 Support</h4>
                    <p>Dedicated support team</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<!-- AOS Library -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script src="~/js/home.js"></script>
<script>
    AOS.init({
        duration: 800,
        easing: 'ease-out-quad',
        once: true
    });
</script>